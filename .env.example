# =============================================================================
# .env.example — Copy this to .env.docker and fill in your secrets
#
# Public vars (NEXT_PUBLIC_*) go in .env for docker-compose build args.
# All secrets & service URLs go in .env.docker (runtime env_file).
# =============================================================================

# ── Clerk ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Use service name from docker-compose when running in containers
MONGODB_URI=mongodb://mongodb:27017/techsphere

# ── RustFS (S3-compatible object storage) ──────────────────────────────────────
RUSTFS_URL=http://rustfs:9000
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=

# ── SMTP ───────────────────────────────────────────────────────────────────────
# Dev: Mailpit (comes with docker-compose, no auth)
# SMTP_HOST=mailpit
# SMTP_PORT=1025
#
# Production: Replace with your SMTP provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=

# ── Mongo Express (web GUI at http://localhost:8081) ───────────────────────────
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin
