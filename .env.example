# =============================================================================
# .env.example — Copy this to .env.docker and fill in your secrets
#
# Public vars (NEXT_PUBLIC_*) go in .env for docker-compose build args.
# All secrets & service URLs go in .env.docker (runtime env_file).
# =============================================================================

# ── Clerk ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Use service name from docker-compose when running in containers
MONGODB_URI=mongodb://mongodb:27017/techsphere

# ── RustFS (S3-compatible object storage) ──────────────────────────────────────
RUSTFS_URL=http://rustfs:9000
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=

# ── Plunk (transactional email) ─────────────────────────────────────────────────
# Get your keys at https://next-app.useplunk.com → Settings → API Keys
PLUNK_SECRET_KEY=sk_
NEXT_PUBLIC_PLUNK_PUBLIC_KEY=pk_
CONTACT_EMAIL=

# ── Base URL (used by payment redirects) ──────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Stripe (payment processing) ─────────────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
# Optional: set in production for webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_

# ── Mongo Express (web GUI at http://localhost:8081) ───────────────────────────
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin
